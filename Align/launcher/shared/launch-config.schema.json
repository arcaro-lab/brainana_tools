{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainana.org/schemas/launch-config-v1.json",
  "title": "Brainana Align launch configuration",
  "type": "object",
  "required": ["schemaVersion", "mode", "root", "cacheRoot", "logRoot", "sessionToken"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "mode": { "enum": ["local", "remote"] },
    "root": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "cacheRoot": { "type": "string", "minLength": 1 },
    "logRoot": { "type": "string", "minLength": 1 },
    "sessionToken": { "type": "string", "minLength": 64 },
    "sshTarget": { "type": "string" },
    "controlSocket": { "type": "string" },
    "sshExecutable": { "type": "string" }
  }
}
