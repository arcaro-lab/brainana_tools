#!/bin/bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
RES="$APP_ROOT/Resources"
VERSION="0.16.0-parity.11"
BUILD_ID="parity-11"

show_error() {
  local message="$1"
  /usr/bin/osascript -e 'on run a' -e 'display alert "Brainana Align" message (item 1 of a) as critical buttons {"OK"}' -e 'end run' -- "$message" >/dev/null 2>&1 || true
}

on_error() {
  local rc=$?
  local line="$1"
  show_error "The launcher stopped unexpectedly at line $line (error $rc). See the launch log in ~/Library/Application Support/Brainana Align/logs/."
  exit "$rc"
}
trap 'on_error $LINENO' ERR

ARCH="$(/usr/bin/uname -m)"
case "$ARCH" in
  arm64) NODE="$RES/runtime/darwin-arm64/node" ;;
  x86_64) NODE="$RES/runtime/darwin-x64/node" ;;
  *) show_error "Unsupported Mac architecture: $ARCH"; exit 31 ;;
esac
[[ -x "$NODE" ]] || { show_error "Bundled runtime missing. Reinstall the complete application."; exit 33; }

SUPPORT="$HOME/Library/Application Support/Brainana Align"
CACHE="$HOME/Library/Caches/Brainana Align/$VERSION"
LOGS="$SUPPORT/logs"
PROFILES="$SUPPORT/profiles.tsv"
mkdir -p "$SUPPORT" "$CACHE" "$LOGS"
touch "$PROFILES"
chmod 600 "$PROFILES"
LOG_FILE="$LOGS/launch-$(/bin/date +%Y%m%d-%H%M%S)-$$.log"
exec > >(tee -a "$LOG_FILE") 2>&1

ask() {
  /usr/bin/osascript -e 'on run a' -e 'text returned of (display dialog (item 1 of a) default answer (item 2 of a) with title "Brainana Align")' -e 'end run' -- "$1" "${2:-}"
}
choose_mode() {
  /usr/bin/osascript -e 'set p to choose from list {"Local files on this Mac", "Remote workstation"} with title "Brainana Align" with prompt "Choose how to access data:" default items {"Local files on this Mac"}' -e 'if p is false then error number -128' -e 'item 1 of p'
}
choose_folder() {
  /usr/bin/osascript -e 'POSIX path of (choose folder with prompt "Choose the folder containing MRI and CT data")'
}
notice() {
  /usr/bin/osascript -e 'on run a' -e 'display dialog (item 1 of a) with title "Brainana Align" buttons {"Continue"} default button "Continue"' -e 'end run' -- "$1" >/dev/null
}
choose_profile() {
  local choices_file="$CACHE/profile-choices-$$.txt"
  /usr/bin/awk -F '\t' 'NF && $1 != "" {print $1}' "$PROFILES" > "$choices_file"
  printf '%s\n' 'Add a new connection...' >> "$choices_file"
  /usr/bin/osascript - "$choices_file" <<'APPLESCRIPT'
on run argv
  set choicesFile to POSIX file (item 1 of argv)
  set rawText to read choicesFile as «class utf8»
  set rawChoices to paragraphs of rawText
  set choices to {}
  repeat with c in rawChoices
    set t to c as text
    if t is not "" then set end of choices to t
  end repeat
  set p to choose from list choices with title "Brainana Align" with prompt "Choose a connection:" default items {item 1 of choices}
  if p is false then error number -128
  return item 1 of p
end run
APPLESCRIPT
  local rc=$?
  rm -f "$choices_file"
  return "$rc"
}
shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | /usr/bin/sed "s/'/'\\''/g")"
}
open_interactive_ssh() {
  local target="$1"
  local socket="$2"
  local status_file="$CACHE/ssh-status-$$"
  rm -f "$status_file" "$socket"
  notice "A Terminal window will open for SSH authentication to $target. Complete any key passphrase, Duo, or keyboard-interactive prompts there. Brainana Align will continue automatically after the connection succeeds."
  local cmd
  cmd="/usr/bin/ssh -M -S $(shell_quote "$socket") -o ControlPersist=600 -o ExitOnForwardFailure=yes -fNT $(shell_quote "$target"); rc=\$?; echo \$rc > $(shell_quote "$status_file")"
  /usr/bin/osascript - "$cmd" <<'APPLESCRIPT'
on run argv
  tell application "Terminal"
    activate
    do script (item 1 of argv)
  end tell
end run
APPLESCRIPT

  local i=0
  while [[ $i -lt 1200 ]]; do
    if /usr/bin/ssh -S "$socket" -O check "$target" >/dev/null 2>&1; then
      rm -f "$status_file"
      return 0
    fi
    if [[ -f "$status_file" ]]; then
      local rc
      rc="$(cat "$status_file" 2>/dev/null || echo 1)"
      rm -f "$status_file"
      show_error "SSH connection to $target failed (error $rc). Review the Terminal window and launch log, then try again."
      return 1
    fi
    /bin/sleep 0.25
    i=$((i+1))
  done
  show_error "SSH authentication did not complete. Review the Terminal window and try again."
  return 1
}

MODE_PICK="$(choose_mode)" || exit 0
MODE="local"
LABEL="This Mac"
ROOT=""
TARGET=""
SOCKET=""

if [[ "$MODE_PICK" == "Local files on this Mac" ]]; then
  ROOT="$(choose_folder)" || exit 0
  ROOT="${ROOT%/}"
else
  MODE="remote"
  LABEL="Remote workstation"
  PICK="$(choose_profile)" || exit 0
  if [[ "$PICK" != "Add a new connection..." ]]; then
    LINE="$(/usr/bin/awk -F '\t' -v n="$PICK" '$1==n{print;exit}' "$PROFILES")"
    [[ -n "$LINE" ]] || { show_error "The selected connection profile could not be found."; exit 36; }
    IFS=$'\t' read -r NAME USER HOST ROOT <<EOF_PROFILE
$LINE
EOF_PROFILE
  else
    NAME="$(ask 'Connection name:' 'Workstation')" || exit 0
    USER="$(ask 'Username:' '')" || exit 0
    HOST="$(ask 'Hostname:' '')" || exit 0
    ROOT="$(ask 'Remote data root:' '')" || exit 0
    [[ -n "$NAME" && -n "$USER" && -n "$HOST" && -n "$ROOT" ]] || { show_error "Connection name, username, hostname, and remote data root are all required."; exit 37; }
    printf '%s\t%s\t%s\t%s\n' "$NAME" "$USER" "$HOST" "$ROOT" >> "$PROFILES"
  fi
  TARGET="$USER@$HOST"
  SOCKET="$CACHE/ssh-control-$$"
  echo "Opening SSH connection to $TARGET..."
  open_interactive_ssh "$TARGET" "$SOCKET"
fi

echo "Brainana Align"
echo "Version: $VERSION"
echo "Build ID: $BUILD_ID"
echo "Launcher: $0"
echo "Mode: $MODE"
echo "Profile: ${NAME:-$LABEL}"
echo "Browser URL: assigned automatically after server start"
echo "Browser port: assigned automatically by macOS"
echo "Local runtime path: $RES/runtime"
echo "Cache path: $CACHE"
echo "Local Node path: $NODE"
echo "Mac architecture: $ARCH"
echo "Data root: $ROOT"
echo "Launch log: $LOG_FILE"
if [[ "$MODE" == "remote" ]]; then
  echo "Remote host: $TARGET"
  echo "Remote data root: $ROOT"
  echo "SSH control socket path: $SOCKET"
  echo "Connection status: connected"
fi

# Each launch receives a private handshake directory. This prevents stale files,
# concurrent launches, and prior browser sessions from affecting port discovery.
UMASK_OLD="$(umask)"
umask 077
LAUNCH_TOKEN="$(/bin/date +%Y%m%d-%H%M%S)-$$-${RANDOM:-0}"
LAUNCH_DIR="$CACHE/launch-$LAUNCH_TOKEN"
/bin/mkdir -p "$LAUNCH_DIR"
umask "$UMASK_OLD"
PORT_FILE="$LAUNCH_DIR/port.txt"
ERROR_FILE="$LAUNCH_DIR/server-error.txt"
rm -f "$PORT_FILE" "$ERROR_FILE"

# Clean only abandoned handshake directories. Active launches have a live PID
# marker and are never touched.
/usr/bin/find "$CACHE" -maxdepth 1 -type d -name 'launch-*' -mtime +2 -exec /bin/rm -rf {} + >/dev/null 2>&1 || true

ARGS=(--host 127.0.0.1 --port 0 --port-file "$PORT_FILE" --error-file "$ERROR_FILE" --root "$ROOT" --mode "$MODE" --label "$LABEL" --cache "$CACHE")
[[ "$MODE" == "remote" ]] && ARGS+=(--ssh-target "$TARGET" --control-socket "$SOCKET")

"$NODE" "$RES/runtime/server.mjs" "${ARGS[@]}" &
PID=$!
printf '%s\n' "$PID" > "$LAUNCH_DIR/server.pid"
cleanup() {
  kill "$PID" 2>/dev/null || true
  /bin/rm -rf "$LAUNCH_DIR"
  if [[ -n "${SOCKET:-}" && -n "${TARGET:-}" ]]; then
    /usr/bin/ssh -S "$SOCKET" -O exit "$TARGET" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

# macOS chooses and binds the port atomically. Wait for the server to publish
# the exact bound port. Use only Bash arithmetic, not nonstandard utilities
# such as seq. The 30-second bound tolerates cold starts and transient system
# load while still failing clearly if the process is unhealthy.
echo "Waiting for the bundled server to publish its assigned browser port..."
PORT=""
ATTEMPT=0
while [[ $ATTEMPT -lt 600 ]]; do
  if [[ -s "$PORT_FILE" ]]; then
    PORT="$(/usr/bin/tr -d '[:space:]' < "$PORT_FILE")"
    if [[ "$PORT" =~ ^[0-9]+$ ]] && [[ "$PORT" -ge 1 ]] && [[ "$PORT" -le 65535 ]]; then
      break
    fi
    PORT=""
  fi
  if [[ -s "$ERROR_FILE" ]]; then
    SERVER_ERROR="$(/bin/cat "$ERROR_FILE" 2>/dev/null || true)"
    show_error "The local Brainana Align server could not start: ${SERVER_ERROR:-unknown server error}. See $LOG_FILE for details."
    exit 34
  fi
  if ! kill -0 "$PID" 2>/dev/null; then
    wait "$PID" || true
    SERVER_ERROR="$(/bin/cat "$ERROR_FILE" 2>/dev/null || true)"
    show_error "The local Brainana Align server stopped before publishing a browser port. ${SERVER_ERROR:-See the launch log for details.} Log: $LOG_FILE"
    exit 34
  fi
  /bin/sleep 0.05
  ATTEMPT=$((ATTEMPT + 1))
done

if [[ -z "$PORT" ]]; then
  show_error "The local Brainana Align server is still running but did not publish a browser port within 30 seconds. See $LOG_FILE for details."
  exit 34
fi

# Use the exact IPv4 address that the server bound. This avoids browser-specific
# localhost resolution differences between IPv4 and IPv6.
URL="http://127.0.0.1:$PORT"
echo "Browser URL: $URL"
echo "Browser port: $PORT"
echo "Waiting for the matching local health endpoint..."

READY=0
ATTEMPT=0
while [[ $ATTEMPT -lt 400 ]]; do
  if /usr/bin/curl --noproxy '*' --connect-timeout 0.25 --max-time 0.75 -fsS "$URL/api/health" >/dev/null 2>&1; then
    READY=1
    break
  fi
  if [[ -s "$ERROR_FILE" ]]; then
    SERVER_ERROR="$(/bin/cat "$ERROR_FILE" 2>/dev/null || true)"
    show_error "The local Brainana Align server reported an error before becoming ready: ${SERVER_ERROR:-unknown server error}. See $LOG_FILE for details."
    exit 34
  fi
  if ! kill -0 "$PID" 2>/dev/null; then
    wait "$PID" || true
    show_error "The local Brainana Align server stopped before becoming ready. See $LOG_FILE for details."
    exit 34
  fi
  /bin/sleep 0.05
  ATTEMPT=$((ATTEMPT + 1))
done

if [[ "$READY" -ne 1 ]]; then
  show_error "The local Brainana Align server did not become ready within 20 seconds. See $LOG_FILE for details."
  exit 34
fi

echo "Local server ready. Opening the macOS default browser: $URL"
/usr/bin/open "$URL" >/dev/null 2>&1 &
OPEN_PID=$!
echo "Default-browser launch requested with PID $OPEN_PID."

wait "$PID"
exit $?
