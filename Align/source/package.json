{
  "name": "brainana-align",
  "private": true,
  "version": "0.17.6-platforms.1",
  "type": "module",
  "scripts": {
    "version:generate": "node ../scripts/generate-version.mjs",
    "dev": "npm run version:generate && vite --host 0.0.0.0",
    "build": "npm run version:generate && tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:server": "node ../tests/server-local-smoke.mjs",
    "verify:release": "node ../scripts/verify-release.mjs",
    "check": "npm run build && npm run test:identity && npm run test:documentation && npm run test:architecture && npm run test:coordinates && npm run test:window-projection && npm run test:windows && npm run test:window-interaction && npm run test:sessions && npm run test:runtime && npm run test:scientific && npm run test:server && npm run test:security && npm run test:browser && npm run test:browser-compat && npm run test:browser-matrix && npm run test:storage && npm run test:local-export && npm run test:platform && npm run test:sftp && npm run test:electron && npm run test:electron-remote && npm run test:remote-endpoint && npm run test:launch-handshake && npm run test:macos-runtime && npm run test:lifecycle && npm run test:lifecycle-detach && npm run test:lifecycle-launchd && npm run test:ssh-cancel && npm run test:ssh-terminal && npm run test:terminal-autoclose && npm run test:local-startup",
    "test:identity": "node ../scripts/check-release-identity.mjs",
    "test:windows": "node ../tests/optimization-windows-unit.mjs",
    "test:architecture": "node ../tests/source-architecture.mjs",
    "test:coordinates": "node ../tests/coordinate-modules-unit.mjs",
    "test:window-projection": "tsx ../tests/window-projection-regression.ts",
    "test:sessions": "node ../tests/session-export-modules-unit.mjs",
    "test:runtime": "node ../tests/runtime-modules-unit.mjs",
    "test:browser": "node ../tests/browser-ui-regression.mjs",
    "test:scientific": "tsx ../tests/scientific-regression.ts",
    "test:security": "node ../tests/server-security.mjs",
    "test:storage": "node ../tests/server-storage.mjs",
    "test:platform": "node ../tests/platform-core.mjs",
    "test:sftp": "node ../tests/sftp-transport.mjs",
    "test:browser-compat": "node ../tests/browser-compatibility.mjs",
    "test:launch-handshake": "python3 ../tests/launch-handshake-stress.py",
    "test:macos-runtime": "bash ../tests/macos-runtime-selection.sh",
    "test:window-interaction": "node ../tests/optimization-window-interaction-unit.mjs",
    "test:local-export": "node ../tests/server-local-export.mjs",
    "test:lifecycle": "bash ../tests/macos-lifecycle-source.sh",
    "test:lifecycle-detach": "python3 ../tests/lifecycle-detach-stress.py",
    "test:lifecycle-launchd": "bash ../tests/macos-launchd-lifecycle.sh",
    "test:ssh-cancel": "bash ../tests/macos-ssh-cancellation.sh",
    "test:ssh-terminal": "bash ../tests/macos-ssh-terminal-launch.sh",
    "test:terminal-autoclose": "bash ../tests/macos-terminal-autoclose.sh",
    "test:browser-matrix": "node ../tests/browser-engine-matrix.mjs",
    "test:local-startup": "bash ../tests/macos-local-startup.sh",
    "test:documentation": "node ../tests/documentation-layout.mjs",
    "electron:start": "npm run build && electron electron/main.mjs",
    "electron:package:mac": "pnpm run build && bash ../scripts/build-electron-macos.sh --assemble-only",
    "test:electron": "node ../tests/electron-source.mjs",
    "test:electron-remote": "node ../tests/electron-remote-source.mjs",
    "test:remote-endpoint": "node ../tests/remote-endpoint-cors.mjs && tsx ../tests/remote-endpoint-state.ts"
  },
  "dependencies": {
    "@niivue/niivue": "^0.69.0",
    "fflate": "^0.8.2",
    "nifti-reader-js": "^0.8.0"
  },
  "devDependencies": {
    "electron": "39.2.7",
    "playwright-core": "^1.61.1",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "main": "electron/main.mjs"
}
