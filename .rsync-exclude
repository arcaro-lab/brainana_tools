# Exclude-from list for copying this project between machines/OSes.
#
# Why: node_modules and build output are PLATFORM-SPECIFIC (e.g. rollup ships
# @rollup/rollup-<os>-<arch> native binaries). Copying them from one machine to
# another gives you the wrong-arch tree and breaks the build with
# "Cannot find module @rollup/rollup-darwin-arm64" (npm/cli#4828).
# Copy source only, then run `npm install` fresh on the target machine.
#
# Usage:
#   rsync -a --exclude-from='.rsync-exclude' ./ user@host:/path/to/brainana_tools/
# (or use --filter=': .gitignore' with git, but this file also works for scp/zip flows)

# Dependencies (platform-specific native binaries — reinstall on target)
node_modules/

# Build output (regenerated by the build on the target)
apps/*/dist/
apps/*/release/

# Generated single-source-of-version module (emitted pre-build; embeds a date)
packages/core-server/version.mjs

# Derived / cache
.brainana-viewer-cache/
*.brainana-partial-*
*.partial-*

# OS / editor
.DS_Store
*.log
.vscode/
.idea/

# Local env (machine-specific secrets/config)
.env
.env.local

# VCS metadata (usually you want git clone/pull instead of copying .git)
.git/
